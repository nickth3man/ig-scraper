# Required for authenticated Instagram access
# Option 1: Session ID (from browser cookies) - preferred method
# Get this from DevTools (F12) → Application → Cookies → instagram.com → sessionid
# Cookie names in cookies.txt: sessionid, csrftoken, datr, mid, ig_did, ds_user_id
INSTAGRAM_SESSIONID=

# Option 2: Username and password (alternative if sessionid doesn't work)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# -----------------------------------------------------------------------------
# Optional tuning for rate limits and retries
# -----------------------------------------------------------------------------

# Timeout for Instagram API requests (default: 30)
# IG_REQUEST_TIMEOUT_SECONDS=30

# Number of comments fetched per pagination page (default: 250)
# IG_COMMENTS_PAGE_SIZE=250

# Delay between requests to avoid rate limiting, in seconds (default: 0.25)
# IG_REQUEST_PAUSE_SECONDS=0.25

# Retry attempts for comment pagination failures (default: 3)
# IG_COMMENT_PAGE_RETRIES=3

# Retry attempts for media download failures (default: 3)
# IG_MEDIA_DOWNLOAD_RETRIES=3
